# ==========================================
# GUARDIAN-OTA Backend Environment
# ==========================================
# Copy this file to .env (add to .gitignore) and customize for your environment

# ========== Network & Port ==========
# HTTP server port for REST API
# ✓ Default: 8080
PORT=8080

# ========== MQTT Broker Configuration ==========
# MQTT broker connection string
# ✓ Development: tcp://localhost:1883 (no auth)
# ✓ Production: tls://broker.example.com:8883 (with TLS)
MQTT_BROKER=tcp://localhost:1883

# Optional: MQTT authentication
# MQTT_USERNAME=ota_backend
# MQTT_PASSWORD=secure_password

# ========== Database Configuration ==========
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database?sslmode=disable
# ✓ Development: postgres://ota:ota@localhost:5432/ota_control?sslmode=disable
# ✓ Production: postgres://user:pass@prod-db.internal:5432/ota_prod?sslmode=require
DATABASE_URL=postgres://ota:ota@localhost:5432/ota_control?sslmode=disable

# ========== Application Configuration ==========
# Gin framework mode
# ✓ debug - Verbose logging, colored output
# ✓ release - Production optimized, minimal logging
GIN_MODE=debug

# ========== Security Configuration ==========
# CORS allowed origins (comma-separated)
# ✓ Development: http://localhost:3000,http://localhost:8080
# ✓ Production: https://dashboard.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ========== Optional: Feature Flags ==========
# ENABLE_METRICS=1
# ENABLE_PROFILING=1

# ========== Optional: Logging ==========
# LOG_LEVEL=info
# LOG_FORMAT=json

