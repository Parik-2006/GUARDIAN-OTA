# ==========================================
# GUARDIAN-OTA Backend Environment
# ==========================================
# Copy this file to .env (add to .gitignore) and customize for your environment

# ========== Network & Port ==========
PORT=8080

# ========== MQTT Broker Configuration ==========
# ✓ Development: tcp://localhost:1883 (no auth)
# ✓ Production: tls://broker.example.com:8883 (with TLS)
MQTT_BROKER=tcp://localhost:1883

# Optional: MQTT authentication
# MQTT_USERNAME=ota_backend
# MQTT_PASSWORD=secure_password

# ========== Database Configuration ==========
# Use the Supabase IPv4 POOLER connection string (port 6543, not 5432)!
# Format: postgres://user:password@host:port/database?sslmode=require
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# DB password (optional separate field)
DB_PASS=

# ========== Blockchain (Sepolia Testnet) ==========
# 64-char hex private key of your Ethereum wallet (NO 0x prefix)
ETH_PRIVATE_KEY=

# Infura / Alchemy RPC endpoint for Sepolia
INFURA_RPC=https://sepolia.infura.io/v3/<your-project-id>

# ========== Application Configuration ==========
# Gin framework mode: debug | release
GIN_MODE=debug

# ========== Security ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ========== Optional Feature Flags ==========
# ENABLE_METRICS=1
# LOG_LEVEL=info
# LOG_FORMAT=json
