# ==========================================
# GUARDIAN-OTA Frontend Environment
# ==========================================
# Copy this file to .env.local and customize for your environment

# Backend API Base URL
# ✓ For local development: http://localhost:8080
# ✓ For production: https://api.yourdomain.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Next.js Environment Mode
# ✓ development - Enable source maps, fast refresh
# ✓ production - Optimized builds, minified output
NODE_ENV=development

# Optional: Enable debug logging
# DEBUG=1

# Optional: Analytics/Telemetry
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# Optional: Sentry Error Tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/yyyy

