# ==========================================
# GUARDIAN-OTA Infrastructure Environment
# ==========================================
# Used by Docker Compose for infrastructure services
# Copy this file to deploy/.env and customize for your environment

# ========== PostgreSQL Configuration ==========
# PostgreSQL admin username and password
POSTGRES_USER=ota
POSTGRES_PASSWORD=ota_secure_password

# PostgreSQL database name
POSTGRES_DB=ota_control

# PostgreSQL port (internal to Docker network)
POSTGRES_PORT=5432

# ========== Mosquitto MQTT Configuration ==========
# MQTT broker will listen on port 1883 (internal)
MQTT_PORT=1883

# Optional: MQTT broker authentication
# MQTT_USERNAME=ota_device
# MQTT_PASSWORD=mqtt_secure_password

# ========== MinIO S3-Compatible Storage ==========
# MinIO admin root user
MINIO_ROOT_USER=minioadmin

# MinIO admin root password
MINIO_ROOT_PASSWORD=minioadmin

# MinIO API port (internal)
MINIO_API_PORT=9000

# MinIO Console port (internal)
MINIO_CONSOLE_PORT=9001

# ========== Application Network ==========
# Network name for Docker Compose services
COMPOSE_PROJECT_NAME=guardian-ota

# Service restart policy
RESTART_POLICY=always
